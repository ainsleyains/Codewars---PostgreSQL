SELECT n,
       CASE
            WHEN n % 2 = 0 THEN (2 - n::bigint) * (n + 2) * (n + 2) / 8
            ELSE -(n::bigint + 1) * (n + 3) * (n + 3) / 8
       END AS res
FROM getsum
